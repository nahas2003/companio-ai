datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum SourceStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  role        Role     @default(STUDENT)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  sources             Source[]
  questionBanks       QuestionBank[]
  practiceSessions    PracticeSession[]
  assessmentTemplates AssessmentTemplate[]
  assessmentAttempts  AssessmentAttempt[]
  notifications       Notification[]
  notificationPreference NotificationPreference?
  organizations       UserOrganization[]

  @@map("users")
}

model Source {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  fileName    String   @map("file_name")
  fileKey     String   @map("file_key")
  fileSize    Int      @map("file_size")
  fileType    String   @map("file_type")
  status      SourceStatus @default(PENDING)
  wordCount   Int?         @map("word_count")
  pageCount   Int?         @map("page_count")
  processedAt DateTime?    @map("processed_at")
  errorMsg    String?      @map("error_msg")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       DocumentContent?
  questionBanks QuestionBank[]

  @@index([userId])
  @@map("sources")
}

model DocumentContent {
  id        String   @id @default(uuid())
  sourceId  String   @unique @map("source_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  source    Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@map("document_contents")
}

model AiUsageLog {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  provider      String
  model         String
  promptName    String   @map("prompt_name")
  promptVersion String   @map("prompt_version")
  durationMs    Int      @map("duration_ms")
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")
  success       Boolean
  errorMsg      String?  @map("error_msg")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("ai_usage_logs")
}

model QuestionBank {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  sourceId    String?  @map("source_id")
  name        String
  description String?
  archived    Boolean  @default(false)
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  source            Source?              @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  questions         Question[]
  practiceSessions  PracticeSession[]
  assessmentTemplates AssessmentTemplate[]

  @@index([userId])
  @@index([sourceId])
  @@map("question_banks")
}

model Question {
  id             String   @id @default(uuid())
  questionBankId String   @map("question_bank_id")
  title          String
  type           QuestionType
  difficulty     Difficulty
  options        String[]
  correctAnswer  Int?         @map("correct_answer")
  modelAnswer    String?      @map("model_answer")
  topic          String?
  archived       Boolean      @default(false)
  deleted        Boolean      @default(false)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  questionBank        QuestionBank         @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
  practiceAnswers     PracticeAnswer[]
  assessmentResponses AssessmentResponse[]

  @@index([questionBankId])
  @@index([topic])
  @@map("questions")
}

model AICache {
  hash      String   @id @unique
  response  String   @map("response") // stringified JSON
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@map("ai_caches")
}

model PracticeSession {
  id             String           @id @default(uuid())
  userId         String?          @map("user_id")
  questionBankId String           @map("question_bank_id")
  score          Float?
  timeTaken      Int?             @map("time_taken")
  status         String           @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user           User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionBank   QuestionBank     @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
  answers        PracticeAnswer[]

  @@index([userId])
  @@index([questionBankId])
  @@map("practice_sessions")
}

model PracticeAnswer {
  id                String          @id @default(uuid())
  practiceSessionId String          @map("practice_session_id")
  questionId        String          @map("question_id")
  selectedOption    Int?            @map("selected_option")
  modelAnswer       String?         @map("model_answer")
  isCorrect         Boolean?        @map("is_correct")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  practiceSession   PracticeSession @relation(fields: [practiceSessionId], references: [id], onDelete: Cascade)
  question          Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([practiceSessionId])
  @@index([questionId])
  @@map("practice_answers")
}

enum GenerationMethod {
  TOPIC
  DESCRIPTION
  DOCUMENT
  QUESTION_BANK
  MANUAL
  IMPORT
}

model AssessmentTemplate {
  id               String                @id @default(uuid())
  creatorId        String                @map("creator_id")
  questionBankId   String                @map("question_bank_id")
  title            String
  description      String?
  timer            Int?                  // timed limit in minutes, null if untimed
  passingScore     Float                 @default(60.0) @map("passing_score")
  shuffleQuestions Boolean               @default(false) @map("shuffle_questions")
  shuffleOptions   Boolean               @default(false) @map("shuffle_options")
  archived         Boolean               @default(false)
  generationMethod GenerationMethod      @default(DOCUMENT) @map("generation_method")
  prompt           String?
  topic            String?
  documentReference String?               @map("document_reference")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  creator          User                  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  questionBank     QuestionBank          @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
  published        PublishedAssessment[]

  @@index([creatorId])
  @@index([questionBankId])
  @@map("assessment_templates")
}

model PublishedAssessment {
  id         String              @id @default(uuid())
  templateId String              @map("template_id")
  code       String              @unique
  active     Boolean             @default(true)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  template   AssessmentTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  attempts   AssessmentAttempt[]

  @@index([templateId])
  @@map("published_assessments")
}

model AssessmentAttempt {
  id                    String               @id @default(uuid())
  publishedAssessmentId String               @map("published_assessment_id")
  userId                String?              @map("user_id")
  guestName             String?              @map("guest_name")
  score                 Float?
  timeTaken             Int?                 @map("time_taken")
  status                String               @default("IN_PROGRESS")
  startedAt             DateTime             @default(now()) @map("started_at")
  completedAt           DateTime?            @map("completed_at")

  publishedAssessment   PublishedAssessment  @relation(fields: [publishedAssessmentId], references: [id], onDelete: Cascade)
  user                  User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses             AssessmentResponse[]

  @@index([publishedAssessmentId])
  @@index([userId])
  @@map("assessment_attempts")
}

model AssessmentResponse {
  id             String            @id @default(uuid())
  attemptId      String            @map("attempt_id")
  questionId     String            @map("question_id")
  selectedOption Int?              @map("selected_option")
  modelResponse  String?           @map("model_response")
  isCorrect      Boolean?          @map("is_correct")
  createdAt      DateTime          @default(now()) @map("created_at")

  attempt        AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionId])
  @@map("assessment_responses")
}

model Notification {
  id        String                @id @default(uuid())
  userId    String                @map("user_id")
  title     String
  message   String
  type      String
  read      Boolean               @default(false)
  deleted   Boolean               @default(false)
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  history   NotificationHistory[]

  @@index([userId])
  @@map("notifications")
}

model NotificationPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  emailEnabled        Boolean  @default(true) @map("email_enabled")
  inAppEnabled        Boolean  @default(true) @map("in_app_enabled")
  reminderPreferences String   @default("daily") @map("reminder_preferences")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model NotificationHistory {
  id             String   @id @default(uuid())
  notificationId String   @map("notification_id")
  channel        String
  status         String
  errorMsg       String?  @map("error_msg")
  sentAt         DateTime @default(now()) @map("sent_at")

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@map("notification_histories")
}

model SystemSetting {
  key       String   @id @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model FeatureFlag {
  key         String   @id @unique
  enabled     Boolean  @default(true)
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  action    String
  target    String
  ipAddress String?  @map("ip_address")
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@map("admin_audit_logs")
}

model ProviderConfig {
  key         String    @id @unique
  name        String
  enabled     Boolean   @default(true)
  costFactor  Float     @default(1.0) @map("cost_factor")
  priority    Int       @default(0)
  status      String    @default("healthy") // healthy, unhealthy
  retryAfter  DateTime? @map("retry_after")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("provider_configs")
}

model ProviderLog {
  id           String   @id @default(uuid())
  provider     String
  model        String
  promptName   String   @map("prompt_name")
  durationMs   Int      @map("duration_ms")
  inputTokens  Int?     @map("input_tokens")
  outputTokens Int?     @map("output_tokens")
  cost         Float?
  success      Boolean
  errorMsg     String?  @map("error_msg")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("provider_logs")
}

model Organization {
  id        String             @id @default(uuid())
  name      String
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  members   UserOrganization[]

  @@map("organizations")
}

model UserOrganization {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  userId         String       @map("user_id")
  role           String       @default("MEMBER") // OWNER, ADMIN, INSTRUCTOR, MEMBER
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("user_organizations")
}
