# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Database Configuration (Prisma)
# Used for general queries (with transaction pooling, port 6543)
DATABASE_URL="postgres://postgres.your-project-ref:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Used for database migrations (direct connection, port 5432)
DIRECT_URL="postgres://postgres.your-project-ref:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# AI Orchestrator Configuration
GEMINI_API_KEY=""
